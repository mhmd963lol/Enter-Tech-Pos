rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Data ──────────────────────────────────────────────────────────
    // Each user can ONLY read/write their own top-level document.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && (!request.resource.data.keys().hasAny(['uid'])
            || request.resource.data.uid == userId)
        && (
          !request.resource.data.keys().hasAny(['profile'])
          || !request.resource.data.profile.keys().hasAny(['role'])
          || request.resource.data.profile.role in ['admin', 'cashier']
        )
        && (
          !request.resource.data.keys().hasAny(['profile'])
          || !request.resource.data.profile.keys().hasAny(['pin'])
          || request.resource.data.profile.pin is string
        );

      // ─── User Subcollections (logs, etc.) ────────────────────────────────
      // The store owner can read/write all subcollections under their own doc.
      // Employees who have been granted access (via employee_access) can also
      // write logs to the store owner's subcollection.
      match /{subcollection}/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
        // Also allow any authenticated user to write logs (for employee login tracking)
        allow create: if request.auth != null && subcollection == 'logs';
      }
    }

    // ─── Phone Mappings ─────────────────────────────────────────────────────
    match /phone_mappings/{phone} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string;
    }

    // ─── Pending Employees ──────────────────────────────────────────────────
    // Any authenticated user can create a pending request (using their own UID as doc ID).
    // Any authenticated user can read pending requests (managers need to see them).
    match /pending_employees/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == docId;
      allow update, delete: if request.auth != null;
    }

    // ─── Employee Access ────────────────────────────────────────────────────
    // Managers create these when approving employees. Any authenticated user
    // can read (needed during login to check if they are an approved employee).
    match /employee_access/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Block everything else ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
